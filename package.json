{
  "name": "sandstorm-capnp-es",
  "version": "0.2.0",
  "description": "Generated TypeScript and ESM bindings for Sandstorm Cap'n Proto schemas.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "default": "./dist/app.js"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "default": "./dist/web.js"
    },
    "./sandstorm/*": {
      "types": "./dist/sandstorm/*.d.ts",
      "default": "./dist/sandstorm/*.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "clean": "node ./scripts/clean.mjs",
    "prepack": "npm run build",
    "test": "npm run build && vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mnutt/capnp-es": "^0.2.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
